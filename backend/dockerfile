FROM node:20-alpine AS builder

WORKDIR /usr/src/app

COPY package*.json ./

RUN npm install

COPY . .

FROM node:20-alpine

WORKDIR /usr/src/app

COPY package*.json ./

RUN npm install --omit=dev && npm cache clean --force

COPY --from=builder /usr/src/app/backend ./backend
COPY --from=builder /usr/src/app/uploads ./uploads

EXPOSE 5000

CMD ["node", "backend/index.js"]
