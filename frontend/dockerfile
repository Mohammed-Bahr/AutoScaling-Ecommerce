# --- Stage 1: Build ---
FROM node:20-alpine AS builder

WORKDIR /usr/src/app

COPY package*.json ./

RUN npm install

COPY . .

# Builds the app, compiles TS, and runs Tailwind's post-css processor
RUN npm run build

# --- Stage 2: Serve ---
FROM nginx:1.25-alpine

# Copy the static build files to Nginx public directory
COPY --from=builder /usr/src/app/dist /usr/share/nginx/html

# Copy custom nginx config for API proxy and React Router paths
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
